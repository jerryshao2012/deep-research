FROM python:3.12.13-slim-bookworm@sha256:d50fb7611f86d04a3b0471b46d7557818d88983fc3136726336b2a4c657aa30b

# Root OCI index above resolves linux/amd64 to
# sha256:72d3d75f2639ab82b34b29390ad3d6e0827c775befee94edda8e9976818f488d.

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    s3fs \
    ripgrep \
    && rm -rf /var/lib/apt/lists/*



# Set up working directory
WORKDIR /deps/deep_research

# Copy the local package
ADD . /deps/deep_research
RUN touch /deps/deep_research/.env

# AWS injects runtime configuration through App Runner and restores persistent
# files directly from S3 in the entrypoint.

# Freeze the Python runtime to the committed lock file. uv creates the runtime
# environment at /deps/deep_research/.venv.
RUN pip install --no-cache-dir "uv==0.8.17" \
    && uv sync --frozen --no-dev

ENV PATH="/deps/deep_research/.venv/bin:$PATH"

# Fail the image build if the exact runtime environment cannot load the S3
# snapshot stack or expose the LangGraph CLI. No AWS credentials are required.
RUN /deps/deep_research/.venv/bin/python -c \
      "import boto3; import langgraph_api; import langgraph_runtime_inmem; import langgraph_snapshot" \
    && test "$(command -v langgraph)" = "/deps/deep_research/.venv/bin/langgraph" \
    && /deps/deep_research/.venv/bin/langgraph dev --help > /dev/null \
    && rm -rf /deps/deep_research/.langgraph_api \
      /deps/deep_research/.langgraph_api.restore-receipt.json \
      /deps/deep_research/..langgraph_api.restore-* \
      /deps/deep_research/..langgraph_api.backup-* \
      /deps/deep_research/..langgraph_api.publish-* \
      /deps/deep_research/..langgraph_api.canonical-* \
      /deps/deep_research/..langgraph_api.restore-receipt.json.*

# Set the host for the dev server
ENV HOST=0.0.0.0
ENV PORT=2024
ENV PYTHONUNBUFFERED=1

EXPOSE 2024

# Copy and set up entrypoint script
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Use entrypoint to setup symlinks
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

# Launch using langgraph dev
CMD ["langgraph", "dev", "--host", "0.0.0.0", "--port", "2024", "--no-reload", "--no-browser"]
