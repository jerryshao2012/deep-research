# API Keys for Deep Research Agent Example
# Copy this file to .env and fill in your actual API keys

VERIFY_SSL=false
# Optional: PEM CA bundle for corporate TLS interception / proxies
# SSL_CERT_FILE=C:/path/to/corp-ca-bundle.pem

# Anthropic API Key (for Claude Sonnet 4)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (for GPT-4o-mini summarization)
OPENAI_API_KEY=your_openai_api_key_here

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint-here
AZURE_OPENAI_DEPLOYMENT=your-azure-openai-deployment-name-here
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Tavily API Key (for web search)
TAVILY_API_KEY=your_tavily_api_key_here

# Ollama Base URL
OLLAMA_BASE_URL=http://localhost:11434

# Ollama Model
OLLAMA_MODEL=glm-4.7-flash:latest

# LangSmith Configuration
LANGCHAIN_TRACING_V2=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=deep-research-deepagents

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Research Agent Configuration
# Maximum number of concurrent research units (sub-agents) that can run simultaneously
MAX_CONCURRENT_RESEARCH_UNITS=3
# Maximum number of iterations per researcher agent before stopping
MAX_RESEARCHER_ITERATIONS=3
# Maximum seconds to wait for wiki ingest to complete (default: 900).
WIKI_INGEST_MAX_WAIT_SECONDS=900

# Wiki Agent Timeouts
WIKI_AGENT_TIMEOUT_SECONDS=600
WIKI_INGEST_PHASE_TIMEOUT_SECONDS=300
WIKI_INDEX_REPAIR_TIMEOUT_SECONDS=180
# Max tool-calling turns per agent invocation (default: 100).
# Large documents with many chunks may need more.
WIKI_AGENT_RECURSION_LIMIT=100
WIKI_QUERY_TIMEOUT_SECONDS=120
WIKI_LINT_TIMEOUT_SECONDS=60

# Maximum retry attempts for the wiki ingestion process (default: 3)
# WIKI_INGEST_MAX_RETRY=3

# Maximum character limit for each content chunk during document ingestion (default: 40000)
# WIKI_MAX_CHUNK_CHARS=40000

# Number of overlapping characters between adjacent chunks during ingestion (default: 2000)
# WIKI_CHUNK_OVERLAP_CHARS=2000

# Maximum character limit for context window inside the wiki service (default: 512000)
# WIKI_CONTEXT_MAX_CHARS=512000

# Explicit base directory override for resolving wiki path directories (defaults to project root / docs folder)
# WIKI_BASE_DIR=./output


# Evaluation Tracking (for langgraph dev server)
# Enable automatic metrics logging during development (true/false)
ENABLE_EVAL_TRACKING=true
# Path to JSONL file for storing operational metrics
EVAL_HISTORY_FILE=./output/eval_history/server_runs.jsonl

# Human-in-the-loop requirement clarification emergency switch (default: true)
# Capable web clients can still choose auto, force, or bypass per run.
ENABLE_REQUIREMENT_CLARIFICATION=true

# =============================================================================
# RELIABILITY & RATE LIMITING
# =============================================================================

# Proactive Rate Shaping (TPM and RPM limits)
# Set these based on your provider's deployment quotas
# Tokens Per Minute:
# Represents the maximum number of tokens (input + output) you are allowed to send to the model provider within a
# rolling 60-second window.
MODEL_TPM=120000
# Requests Per Minute:
# Represents the maximum number of individual API calls you can make per minute.
MODEL_RPM=500

# Graph Recursion Limit
# Controls the maximum depth of recursive graph execution in LangGraph
# Default LangGraph recursion limit is 100, but deep research workflows often require more iterations
# Increase this value for complex multi-agent research tasks that involve many sub-agent delegations
GRAPH_RECURSION_LIMIT=200

# Reactive Retries (Optional Exponential Backoff and Jitter)
# Maximum number of retry attempts when rate limit errors occur
MODEL_MAX_RETRIES=5
# Initial backoff time in seconds before first retry
MODEL_INITIAL_BACKOFF=1.0
# Maximum backoff time in seconds (cap for exponential backoff)
MODEL_MAX_BACKOFF=60.0
# Multiplier for exponential backoff (backoff = initial * multiplier^attempt)
MODEL_BACKOFF_MULTIPLIER=2.0
# Add jitter to prevent thundering herd problem (true/false)
MODEL_RETRY_JITTER=true

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================

# API Key for document upload endpoint authentication (webapp.py)
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Note: For simplicity, you can use the same key as LANGGRAPH_API_KEY
UPLOAD_API_KEY=your_secure_upload_api_key_here

# Host and port for the document upload API server
# Use 0.0.0.0 to listen on all interfaces (for public access)
UPLOAD_HOST=0.0.0.0
UPLOAD_PORT=8000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database type: sqlite, cosmosdb, postgres (default: sqlite)
DB_TYPE=sqlite

# Checkpointer memory persistence type: memory, sqlite, postgres, cosmosdb (defaults to none/unset which uses platform management)
# MEMORY_TYPE=memory


# SQLite Configuration (Used if DB_TYPE=sqlite)
# Leaving this empty or not set will default to an in-memory database (:memory:)
# SQLITE_DB_PATH=./output/deep_research.db

# Azure Cosmos DB Configuration (Used if DB_TYPE=cosmosdb)
# COSMOSDB_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
# COSMOSDB_KEY=your-cosmos-key-here
# COSMOSDB_DB_NAME=deep_research
# COSMOS_CONNECTION_STRING=your-cosmos-connection-string (alternative to endpoint/key)

# PostgreSQL Configuration (Used if DB_TYPE=postgres)
# DATABASE_URL=postgresql://username:password@localhost:5432/dbname
# Or configure connection parameters individually:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password
# POSTGRES_DB=postgres

# =============================================================================
# OAUTH CONFIGURATION (Migrated from Frontend)
# =============================================================================

# ============================================
# Google OAuth Configuration
# ============================================
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Navigate to APIs & Services > OAuth consent screen (External or Internal)
# 4. Navigate to APIs & Services > Credentials > Create Credentials > OAuth 2.0 Client ID
# 5. Application type: Web application
# 6. Authorized JavaScript origins: http://localhost:3000 (frontend)
# 7. Authorized redirect URIs: http://localhost:2024/auth/callback/google (backend)
# 8. Copy Client ID and Client Secret below
# Note: LangGraph dev server runs on port 2024, frontend UI on port 3000
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# GitHub OAuth Configuration
# ============================================
# 1. Go to https://github.com/settings/developers
# 2. Click "OAuth Apps" -> "New OAuth App"
# 3. Create TWO apps: one for local, one for production
#
# Local Development App:
#   - Application name: BMO Deep Agent Local
#   - Homepage URL: http://localhost:3000
#   - Authorization callback URL: http://localhost:2024/auth/callback/github
#
# Production App:
#   - Application name: BMO Deep Agent
#   - Homepage URL: https://deepagent-ui.salmonrock-b46ff20d.canadacentral.azurecontainerapps.io
#   - Authorization callback URL: https://deep-research-agent-0312.salmonrock-b46ff20d.canadacentral.azurecontainerapps.io/auth/callback/github
#
# 4. Copy Client ID and Client Secret from your LOCAL app for development
# Note: 
#   - LangGraph dev server runs on port 2024, frontend UI on port 3000
#   - GitHub OAuth Client Secret is DIFFERENT from Personal Access Tokens
#   - You must generate a new client secret after app creation (shown only once)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================
# OAuth Session Security
# ============================================
# Secret key for signing session tokens (auto-generated if not set)
# Tip: You can generate a good random string for OAUTH_SECRET_KEY by running `openssl rand -base64 32` in your terminal
OAUTH_SECRET_KEY=your-secret-key-for-session-signing

# Frontend URLs to redirect after successful OAuth callback (comma-separated if multiple)
# Local development: http://localhost:3000
# Production: Your deployed frontend URL(s)
FRONTEND_URLS=http://localhost:3000

# =============================================================================
# DEVELOPMENT / TESTING OPTIONS
# =============================================================================

# Enable test mode to bypass OAuth identity checks and allow access to all threads (true/false)
ALLOW_ALL_THREADS=false
