#!/bin/bash
# =============================================================================
# Secrets Configuration Template for Deep Research Agent on AWS
# =============================================================================
# IMPORTANT: This is a TEMPLATE file. DO NOT commit your actual secrets here.
# 
# Instructions:
# 1. Copy this file to secrets-aws.sh: cp secrets-aws.sh.example secrets-aws.sh
# 2. Replace the placeholder values below with your actual API keys
# 3. Run the script: ./secrets-aws.sh
# =============================================================================

source ./env-aws.sh

echo "🔐 Setting secrets in AWS Secrets Manager: $SECRETS_MANAGER_NAME"

# Check if AWS CLI is configured
aws sts get-caller-identity &>/dev/null || { echo "❌ AWS CLI not authenticated. Run 'aws configure' first."; exit 1; }

# API Keys and endpoints configuration
TAVILY_API_KEY="YOUR_TAVILY_API_KEY_HERE"
LANGCHAIN_API_KEY="YOUR_LANGCHAIN_API_KEY_HERE"
AZURE_OPENAI_ENDPOINT="https://YOUR_RESOURCE_NAME.cognitiveservices.azure.com/"
AZURE_OPENAI_DEPLOYMENT="YOUR_DEPLOYMENT_NAME"
AZURE_OPENAI_API_KEY="YOUR_AZURE_OPENAI_API_KEY_HERE"
UPLOAD_API_KEY="YOUR_UPLOAD_API_KEY_HERE"
LANGGRAPH_API_KEY="YOUR_LANGGRAPH_API_KEY_HERE"

# Construct JSON payload
SECRET_JSON=$(cat <<EOF
{
  "TAVILY-API-KEY": "$TAVILY_API_KEY",
  "LANGCHAIN-API-KEY": "$LANGCHAIN_API_KEY",
  "AZURE-OPENAI-ENDPOINT": "$AZURE_OPENAI_ENDPOINT",
  "AZURE-OPENAI-DEPLOYMENT": "$AZURE_OPENAI_DEPLOYMENT",
  "AZURE-OPENAI-API-KEY": "$AZURE_OPENAI_API_KEY",
  "UPLOAD-API-KEY": "$UPLOAD_API_KEY",
  "LANGGRAPH-API-KEY": "$LANGGRAPH_API_KEY"
}
EOF
)

# Check if secret already exists
if aws secretsmanager describe-secret --secret-id "$SECRETS_MANAGER_NAME" --region "$AWS_REGION" &>/dev/null; then
  echo "📝 Secret already exists. Updating secret value..."
  aws secretsmanager put-secret-value \
    --secret-id "$SECRETS_MANAGER_NAME" \
    --secret-string "$SECRET_JSON" \
    --region "$AWS_REGION" > /dev/null
else
  echo "✨ Creating new secret in AWS Secrets Manager..."
  aws secretsmanager create-secret \
    --name "$SECRETS_MANAGER_NAME" \
    --secret-string "$SECRET_JSON" \
    --region "$AWS_REGION" > /dev/null
fi

echo "✅ All secrets have been set in AWS Secrets Manager"
echo "💡 You can now run ./deploy-aws.sh to deploy with these secrets"
