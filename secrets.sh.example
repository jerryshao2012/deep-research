#!/bin/bash
# =============================================================================
# Secrets Configuration Template for Deep Research Agent
# =============================================================================
# IMPORTANT: This is a TEMPLATE file. DO NOT commit your actual secrets here.
# 
# Instructions:
# 1. Copy this file to secrets.sh: cp secrets.sh.example secrets.sh
# 2. Replace the placeholder values below with your actual API keys
# 3. Run the script: ./secrets.sh
# 4. Delete or secure your secrets.sh file after running (it contains real secrets)
#
# Alternative: Set environment variables before running deploy.sh:
#   export TAVILY_API_KEY="your-actual-key"
#   export LANGCHAIN_API_KEY="your-actual-key"
#   etc.
# =============================================================================

source ./env.sh

echo "🔐 Setting secrets in Azure Key Vault: $KV_NAME"

# =============================================================================
# SEARCH ENGINE API KEYS
# =============================================================================

# Tavily API Key (Required for web search)
# Get your free API key at: https://app.tavily.com
az keyvault secret set --vault-name $KV_NAME --name TAVILY-API-KEY --value "YOUR_TAVILY_API_KEY_HERE"

# =============================================================================
# LANGCHAIN/LANGSMITH CONFIGURATION
# =============================================================================

# LangSmith API Key (for tracing and monitoring)
# Get your key at: https://smith.langchain.com/settings
az keyvault secret set --vault-name $KV_NAME --name LANGCHAIN-API-KEY --value "YOUR_LANGCHAIN_API_KEY_HERE"

# =============================================================================
# AZURE OPENAI CONFIGURATION
# =============================================================================

# Azure OpenAI Endpoint
# Format: https://<your-resource-name>.cognitiveservices.azure.com/
az keyvault secret set --vault-name $KV_NAME --name AZURE-OPENAI-ENDPOINT --value "https://YOUR_RESOURCE_NAME.cognitiveservices.azure.com/"

# Azure OpenAI Deployment Name
# The name of your model deployment in Azure OpenAI Studio
az keyvault secret set --vault-name $KV_NAME --name AZURE-OPENAI-DEPLOYMENT --value "YOUR_DEPLOYMENT_NAME"

# Azure OpenAI API Key
# Found in Azure Portal > Your OpenAI resource > Keys and Endpoint
az keyvault secret set --vault-name $KV_NAME --name AZURE-OPENAI-API-KEY --value "YOUR_AZURE_OPENAI_API_KEY_HERE"

# =============================================================================
# DOCUMENT UPLOAD API CONFIGURATION
# =============================================================================

# API Key for document upload endpoint authentication
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
az keyvault secret set --vault-name $KV_NAME --name UPLOAD-API-KEY --value "YOUR_UPLOAD_API_KEY_HERE"

echo "✅ All secrets have been set in Key Vault"
echo "💡 You can now run ./deploy.sh to deploy with these secrets"
echo ""
echo "⚠️  SECURITY WARNING: Delete or secure secrets.sh after running!"
echo "    rm secrets.sh  # or move it to a secure location"
